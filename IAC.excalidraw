      "frameId": null,
      "index": "b00",
      "roundness": null,
      "seed": 1518802498,
      "version": 406,
      "versionNonce": 1026620610,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779038615942,
      "link": null,
      "locked": false,
      "text": "To check the list only your of Service Principals in the Azure subscription\naz ad sp list --show-mine -o table",
      "fontSize": 15.84344096220251,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To check the list only your of Service Principals in the Azure subscription\naz ad sp list --show-mine -o table",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nNFXi8iQduhUOdjMhtaNh",
      "type": "text",
      "x": -193.10127407160314,
      "y": 2161.1564424759426,
      "width": 716.2180080651623,
      "height": 59.41290360825942,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "6rO55bf7Pu324Eca7eDUe",
        "JmefQHyqBvzGlqxaDKZUV"
      ],
      "frameId": null,
      "index": "b01",
      "roundness": null,
      "seed": 1027090626,
      "version": 343,
      "versionNonce": 624432258,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779038615942,
      "link": null,
      "locked": false,
      "text": "How to Grant a Service Principal Access to the Azure Container Registry\n  ACR_ID=$(terraform output cr_id)\n  az role assignment create --assignee $TF_VAR_client_id --role acrpull  --scope \"$ACR_ID\"",
      "fontSize": 15.843440962202509,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to Grant a Service Principal Access to the Azure Container Registry\n  ACR_ID=$(terraform output cr_id)\n  az role assignment create --assignee $TF_VAR_client_id --role acrpull  --scope \"$ACR_ID\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
