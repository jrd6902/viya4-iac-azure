      "boundElements": null,
      "updated": 1779038615942,
      "link": null,
      "locked": false,
      "text": "az identity create --resource-group <my resource group> --name <my identity name>\nPID=$(az identity show --resource-group <my resource group> --name <my identity name> --output tsv --query principalId)\naz role assignment create --assignee $PID --role Contributor",
      "fontSize": 15.84344096220251,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "az identity create --resource-group <my resource group> --name <my identity name>\nPID=$(az identity show --resource-group <my resource group> --name <my identity name> --output tsv --query principalId)\naz role assignment create --assignee $PID --role Contributor",
      "autoResize": true,
      "lineHeight": 1.25
    },
