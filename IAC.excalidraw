      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How to Create a User-assigned Managed Identity with the Contributor Role",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "33sNhcac55eE0zGAQrxar",
      "type": "text",
      "x": -188.15019877091515,
      "y": 2372.072250285263,
      "width": 946.042862094155,
      "height": 59.41290360825942,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
