      "text": "docker run \\\n --rm \\\n --group-add root \\\n --user \"$(id -u):$(id -g)\" \\\n --env-file $HOME/{{my-viya-project}}/infrastructure/{{creds_path}}/.creds.env \\\n --volume $HOME/{{my-viya-project}}/infrastructure:/workspace \\\n --volume $HOME/{{my-viya-project}}/infrastructure/.ssh:/ssh_folder \\\n viya4-iac-azure:v10.8.0 \\\n   plan \\\n   -var-file /workspace/terraform.tfvars \\\n   -state /workspace/terraform.tfstate",
