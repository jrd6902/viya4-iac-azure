      "type": "text",
      "x": -188.15019877091515,
      "y": 1264.6157270273084,
      "width": 916.5107616331334,
      "height": 59.41290360825942,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
